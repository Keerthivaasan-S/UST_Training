let dtr:String = 'correspondence';
let cist: number[]= Array(26).fill(0);
let count:number=0;
for(let i=0;i<dtr.length;i++)
{
    let x:number = dtr.charCodeAt(i)-'a'.charCodeAt(0);
    cist[x]=cist[x]+1;
}
for(let i=0;i<dtr.length;i++)
{
    if(cist[dtr.charCodeAt(i)-97]==1)
    {
        if(dtr.charAt(i)=='a'||dtr.charAt(i)=='e'||dtr.charAt(i)=='i'||dtr.charAt(i)=='o'||dtr.charAt(i)=='u')
        {
            count++;
        }
    }
}
console.log(`${count} Unqiue Vowels`);
